{
  "version": 2,
  "builds": [
    { "src": "main.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/auth/register", "dest": "main.py" },
    { "src": "/auth/login", "dest": "main.py" },
    { "src": "/auth/me", "dest": "main.py" },
    { "src": "/tutor/generate", "dest": "main.py" },
    { "src": "/docs", "dest": "main.py" },
    { "src": "/openapi.json", "dest": "main.py" },
    { "src": "/(.*)", "dest": "index.html" }
  ]
}